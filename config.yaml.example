# RemoteTerm SPI Node Configuration
#
# This file configures RemoteTerm to drive a LoRa radio directly over SPI,
# turning a Raspberry Pi + LoRa HAT into a self-contained MeshCore node.
#
# Usage:
#   1. Copy this file to data/config.yaml
#   2. Adjust the settings below for your hardware and region
#   3. Start RemoteTerm — it will detect the config file automatically
#
# Prerequisites:
#   - Enable SPI on your Pi:  sudo raspi-config → Interface Options → SPI
#   - Install SPI extras:     pip install -e ".[spi]"

node:
  # Node name visible on the mesh network
  name: "RemoteTerm"

  # Geographic coordinates for advertisements (optional)
  latitude: 0.0
  longitude: 0.0

# Radio parameters — must match other nodes on your mesh
radio:
  # Frequency in Hz
  # USA/Canada (Recommended): 910525000
  # EU/UK (Narrow):           869618000
  # Australia:                 915800000
  # New Zealand:               917375000
  frequency: 910525000

  # TX power in dBm (max 22 for SX1262, 30 for PiMesh-1W)
  tx_power: 22

  # LoRa modulation settings
  # USA/Canada: SF7 / BW62500 / CR5
  # EU/UK:      SF8 / BW62500 / CR8
  bandwidth: 62500
  spreading_factor: 7
  coding_rate: 5

  # Packet framing
  preamble_length: 17
  sync_word: 13380  # 0x3444 — MeshCore network

# Hardware profile — selects GPIO pin mappings for your board
#
# Supported profiles:
#   waveshare      — Waveshare LoRa HAT (SPI version)
#   uconsole       — uConsole LoRa Module (HackerGadgets All-In-One)
#   pimesh-1w-usa  — PiMesh-1W (USA, 30dBm capable)
#   pimesh-1w-uk   — PiMesh-1W (UK)
#   meshadv-mini   — FrequencyLabs meshadv-mini
#   meshadv        — FrequencyLabs meshadv
#   ht-ra62        — Heltec HT-RA62 Module
hardware:
  profile: "waveshare"

  # Advanced: override individual pins from the profile (optional)
  # Uncomment only if your wiring differs from the standard profile.
  # bus_id: 0
  # cs_pin: 21
  # reset_pin: 18
  # busy_pin: 20
  # irq_pin: 16

# Logging level: DEBUG, INFO, WARNING, ERROR
logging:
  level: INFO
